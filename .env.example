# Configuración para entorno local de desarrollo
# Copia este archivo a .env y reemplaza los valores con tus credenciales reales

# Entorno Flask
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_SECRET_KEY=clave_secreta_para_desarrollo_local_1234567890

# Google Calendar API (credenciales JSON)
GOOGLE_CREDENTIALS={"type": "service_account", "project_id": "dummy-project", "private_key_id": "dummy-key-id", "private_key": "-----BEGIN PRIVATE KEY-----\nDUMMY_KEY\n-----END PRIVATE KEY-----\n", "client_email": "dummy@dummy-project.iam.gserviceaccount.com", "client_id": "1234567890", "auth_uri": "https://accounts.google.com/o/oauth2/auth", "token_uri": "https://oauth2.googleapis.com/token", "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs", "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/dummy%40dummy-project.iam.gserviceaccount.com"}

# Groq API
GROQ_API_KEY=gsk_dummykey1234567890abcdefghijklmnopqrstuvwxyz

# Email del psicólogo
PSICOLOGO_EMAIL=psicologo@ejemplo.com

# Resend API para envío de correos
RESEND_API_KEY=re_dummykey1234567890abcdefghijklmnopqrstuvwxyz
RESEND_FROM_EMAIL=equilibra@tudominio.com

# Configuraciones adicionales
PORT=5000
RENDER_EXTERNAL_HOSTNAME=localhost:5000

# Base de datos PostgreSQL (panel administrativo)
# Formato: postgresql://usuario:contraseña@host:5432/nombre_db
# Para desarrollo local puedes usar SQLite (se crea automáticamente):
# DATABASE_URL=sqlite:///equilibra_dev.db
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/equilibra

# Credenciales del panel administrativo
ADMIN_EMAIL=admin@equilibra.com
ADMIN_PASSWORD=Equilibra2025!
ADMIN_NAME=Administrador